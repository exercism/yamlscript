!yamlscript/v0

defn classify(number):
  when-not number.+?:
    die: 'Classification is only possible for positive integers.'

  case compare(sum-of-divisors(number), number):
    0  :: perfect
    1  :: abundant
    -1 :: deficient

defn sum-of-divisors(number):
  sum:
    for n range(1 quot(number 2).++) :when (number % n).0?: n
