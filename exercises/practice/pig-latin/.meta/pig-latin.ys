!yamlscript/v0

logic =::
  ! /^(?:[aeiou]|yt|xr).*/                 :: \(_ + 'ay')
  ! /^(s?qu|thr|sch|[crst]h|[^aeiou])(.*)/ :: \("$(_.2)$(_.1)ay")

defn translate(phrase): words(phrase).map(pig-latin).joins()

defn pig-latin(word):
  reduce-kv _ nil logic:
    fn(translated regex function):
      match =: word =~ regex
      translated ||: match && function(match)
